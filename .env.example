# Halo Stats — configuration template
# Copy to .env and fill in your values. Required vars are marked; everything
# else is optional and the feature it powers stays off (or uses the shown
# default) when unset.

# ── Database (REQUIRED) ─────────────────────────────────────────────────────
HALO_DB_PASSWORD=change_me_strong_password
HALO_DB_NAME=halodb
HALO_DB_USER=postgres
HALO_DB_HOST=halodb
HALO_DB_PORT=5432

# ── Halo/Xbox API via Azure AD app registration (OPTIONAL — /setup is easier) ─
# The easy way: leave these unset and complete everything on the app's /setup
# page — paste your Azure app's client ID + secret there (saved to
# api_config.json in the data dir, which takes priority over these env vars)
# and click "Authorize with Xbox Live" to mint tokens.json in-app.
# Advanced/env alternative: create an app at https://portal.azure.com →
# App registrations, add a "Mobile and desktop" redirect URI of
# http://localhost, set the vars below, then run `python src/auth.py` once.
#HALO_CLIENT_ID=your_azure_client_id_here
#HALO_CLIENT_SECRET=your_azure_client_secret_here
#HALO_REDIRECT_URI=http://localhost

# ── Players to track (OPTIONAL — the in-app /setup page is the easy way) ────
# Players are normally entered on the app's /setup page (saved to players.json
# in the data dir, hot-reloaded by the scraper). This env var is a fallback used
# only when players.json doesn't exist: a JSON array of gamertags + XUIDs.
#HALO_TRACKED_PLAYERS='[{"gamertag": "PlayerOne", "xuid": "2533274800000001"}, {"gamertag": "PlayerTwo", "xuid": "2533274800000002"}]'

# ── Web app (REQUIRED) ───────────────────────────────────────────────────────
HALO_SECRET_KEY=change_this_to_a_long_random_string
HALO_ADMIN_USER=admin
HALO_ADMIN_PASSWORD=change_this_admin_password
HALO_WEB_PORT=8091
HALO_SITE_TITLE=Halo Stats
HALO_TZ=UTC
TZ=UTC
HALO_DATA_DIR=/data

# ── Scraper tuning (optional) ────────────────────────────────────────────────
HALO_MATCH_LIMIT=100
HALO_UPDATE_INTERVAL=60
HALO_UPDATE_INTERVAL_ACTIVE=15
HALO_CACHE_TTL=120

# ── Twitch integration (optional — live page embeds + go-live alerts) ───────
# App credentials from https://dev.twitch.tv/console/apps (client credentials
# flow; no user auth needed). Map each gamertag to their Twitch login:
#   HALO_TWITCH_CHANNELS='{"PlayerOne": "playerone_ttv", "PlayerTwo": "ptwo"}'
#TWITCH_CLIENT_ID=
#TWITCH_CLIENT_SECRET=
#HALO_TWITCH_CHANNELS=

# ── ntfy push alerts (optional — session/go-live notifications) ──────────────
#HALO_NTFY_ENABLED=1
#HALO_NTFY_URL=https://ntfy.sh
#HALO_NTFY_TOPIC=your-unique-topic

# ── Web Push notifications (optional) ────────────────────────────────────────
# A VAPID keypair is generated automatically into the data dir on first use.
# Set the contact subject for the push service:
#HALO_VAPID_SUBJECT=mailto:you@example.com

# ── AI Coach via Ollama (optional) ───────────────────────────────────────────
#HALO_OLLAMA_URL=http://your-ollama-host:11434
#HALO_OLLAMA_MODEL=llama3.1:8b

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_DEBUG=False
FLASK_ENV=production
